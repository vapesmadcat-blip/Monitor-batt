            dependencyResolutionManagement {
                repositoriesMode.set(RepositoriesMode.PREFER_SETTINGS)
                    repositories {
                            google()
                                    mavenCentral()
                                        }
                                        }
                                        rootProject.name = "BatteryMonitor"
                                        include ':app'
                                        EOF
                                        echo "✅ settings.gradle atualizado."
                                        
                                        # 4. Corrigir build.gradle (remover blocos repositories)
                                        echo "📝 Corrigindo build.gradle..."
                                        
                                        # Criar um novo build.gradle temporário
                                        cat > build.gradle.new << 'EOF'
                                        // Top-level build file where you can add configuration options common to all sub-projects/modules.
                                        plugins {
                                            id 'com.android.application' version '8.5.0' apply false
                                                // Adicione outros plugins se necessário (ex: com.android.library)
                                                }
                                                
                                                buildscript {
                                                    dependencies {
                                                            classpath 'com.android.tools.build:gradle:8.5.0'
                                                                }
                                                                }
                                                                
                                                                tasks.register('clean', Delete) {
                                                                    delete rootProject.buildDir
                                                                    }
                                                                    EOF
                                                                    
                                                                    # Se o build.gradle original tiver configurações extras (como outras dependências ou plugins),
                                                                    # podemos tentar preservar a parte depois de 'allprojects' ou 'android'? Mas o mais seguro é
                                                                    # manter a estrutura mínima acima. O usuário pode ter configurações específicas, então
                                                                    # vamos verificar se existe um bloco 'subprojects' ou 'ext' e tentar mantê-los.
                                                                    
                                                                    # Backup do original para possível mesclagem manual
                                                                    echo "⚠️  O script substituiu o build.gradle por uma versão limpa."
                                                                    echo "Se você tinha configurações personalizadas (ex: ext, subprojects), será necessário adicioná-las manualmente."
                                                                    echo "O arquivo original foi salvo em: $BACKUP_DIR/build.gradle.bak"
                                                                    
                                                                    # Substituir o build.gradle antigo pelo novo
                                                                    mv build.gradle.new build.gradle
                                                                    
                                                                    echo "✅ build.gradle atualizado."
                                                                    
                                                                    # 5. Garantir que gradlew tem permissão de execução
                                                                    if [ -f "gradlew" ]; then
                                                                        chmod +x gradlew
                                                                            echo "✅ gradlew agora é executável."
                                                                            else
                                                                                echo "⚠️  gradlew não encontrado. Execute 'gradle wrapper' para gerá-lo."
                                                                                
                                                                                fi
                                                                                
                                                                                echo ""
                                                                                echo "🎉 Correção concluída! Agora faça commit e push para o GitHub:"
                                                                                echo "   git add build.gradle settings.gradle"
                                                                                echo "   git commit -m \"Corrige conflito de repositórios Gradle\""
                                                                                echo "   git push origin main"
                                                                                echo ""
                                                                                echo "Depois o GitHub Actions de
                                                                                ve compilar com sucesso."
