<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Topo: Gauge (esquerda) + Toggle de tema (direita) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Card de Estatística (Esquerda) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/stat_card_background"
                android:padding="12dp"
                android:elevation="2dp">

                <!-- Cabeçalho: indicador + STATUS + badge de velocidade -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <!-- Indicador Visual (Raio ⚡ ou Seta ⬇️) -->
                    <TextView
                        android:id="@+id/tvVisualIndicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"/>

                    <!-- Título fixo "STATUS" -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="STATUS"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <!-- Badge de velocidade (Lento / Normal / Rápido) -->
                    <TextView
                        android:id="@+id/tvChargingSpeedLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textColor="#F59E0B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/stat_badge_background"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"/>
                </LinearLayout>

                <!-- Linha principal: ícone de velocidade + taxa/tempo -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <!-- Ícone de velocidade -->
                    <ImageView
                        android:id="@+id/ivChargingSpeedIcon"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_charging_fast"
                        android:scaleType="fitCenter"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Taxa de carregamento (%/min) -->
                        <TextView
                            android:id="@+id/tvChargingRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <!-- Tempo estimado -->
                        <TextView
                            android:id="@+id/tvChargingTimeRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Gauge visual (ProgressBar horizontal) -->
                <ProgressBar
                    android:id="@+id/pbChargingSpeed"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progress="50"
                    android:progressDrawable="@drawable/charging_gauge"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp"/>

                <!-- Mini-grid de estatísticas: corrente / potência -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Corrente"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"/>
                        <TextView
                            android:id="@+id/tvBatteryCurrent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Potência"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"/>
                        <TextView
                            android:id="@+id/tvBatteryPower"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Mini-grid de estatísticas: temperatura / tensão -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperatura"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"/>
                        <TextView
                            android:id="@+id/tvBatteryTemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tensão"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp"/>
                        <TextView
                            android:id="@+id/tvBatteryVoltage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Toggle de tema (Direita) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_light"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchThemeMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@string/theme_toggle_description"
                    app:useMaterialThemeColors="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_dark"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitor de Bateria Pro"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- ============================================================ -->
        <!-- ALERTA DE MAU CONTATO (oculto por padrão)                    -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/layoutBadContactAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFF3B30"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ POSSÍVEL PROBLEMA NO CABO"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detectada possibilidade de mau contato"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnDismissBadContact"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="OK"
                android:textColor="#FF3B30"
                android:backgroundTint="#FFFFFF"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"/>
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- BATERIA + MASCOTE (Centralizado)                             -->
        <!-- ============================================================ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/batteryContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="160dp"
                    android:layout_height="300dp">

                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/battery_shell"/>

                    <View android:id="@+id/batteryFill"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/battery_fill_high"/>

                    <View android:layout_width="match_parent" android:layout_height="match_parent"
                        android:background="@drawable/battery_gloss"/>

                    <TextView android:id="@+id/tvChargingBolt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="⚡"
                        android:textColor="#FFD700"
                        android:textSize="48sp"
                        android:visibility="gone"/>
                </FrameLayout>

                <TextView android:id="@+id/tvLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="87%"
                    android:textColor="#4ADE80"
                    android:textSize="42sp"
                    android:textStyle="bold"/>

                <TextView android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NORMAL"
                    android:textColor="#4ADE80"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageView android:id="@+id/ivMascot"
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:scaleType="fitCenter"
                android:src="@drawable/battery_mascot_1"/>
        </FrameLayout>

        <!-- Porcentagem Grande -->
        <TextView android:id="@+id/tvBigPercentage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#4ADE80"
            android:textSize="68sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Indicador de Bip (feedback visual) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔊 BIP (pisca quando toca)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="2dp"/>

        <TextView android:id="@+id/tvBipIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔊"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- ============================================================ -->
        <!-- BOTÃO MONITOR (ÚNICO)                                         -->
        <!-- ============================================================ -->
        <Button
            android:id="@+id/btnMonitor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="▶ ATIVAR MONITOR"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#22C55E"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:elevation="4dp" />

        <!-- ============================================================ -->
        <!-- BOTÕES SILENCIAR + SOBRE                                      -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnMute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="🔊 Silenciar"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/btnSobre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="ℹ️ Sobre"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />

        </LinearLayout>

        <!-- Configurações -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Configurações" android:textColor="@color/text_secondary"
            android:textSize="14sp" android:layout_marginBottom="8dp"/>

        <!-- Threshold -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Alerta a partir de:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvThresholdValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="15%" android:textColor="#4ADE80" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <!-- Intervalo -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Intervalo do bip:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvIntervalValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="30 segundos" android:textColor="#4ADE80" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <!-- ============================================================ -->
        <!-- SWITCHES DE ÁUDIO                                             -->
        <!-- ============================================================ -->

        <!-- Switch Bip (independente) -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchBeep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Ativar Bip"
            android:checked="false"
            android:textColor="@color/text_primary"
            app:useMaterialThemeColors="true" />

        <!-- Separador de grupo exclusivo -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Modo de voz (escolha um):"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="8dp"/>

        <!-- Switch TTS (exclusivo com Personagem) -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Ativar TTS (síntese de voz)"
            android:checked="false"
            android:textColor="@color/text_primary"
            app:useMaterialThemeColors="true" />

        <!-- Switch Personagem (exclusivo com TTS) -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchCharacterVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Ativar Voz do Personagem"
            android:checked="false"
            android:textColor="@color/text_primary"
            app:useMaterialThemeColors="true" />

        <!-- ============================================================ -->
        <!-- VOLUME DA VOZ                                                  -->
        <!-- ============================================================ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Volume da voz:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvVoiceVolumeValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="80%" android:textColor="#4ADE80" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekVoiceVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80"
            android:layout_marginBottom="24dp"/>

        <!-- Estilo Visual -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Estilo Visual:" android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <Spinner android:id="@+id/spinnerVisualStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_box_background"
            android:popupBackground="@color/spinner_dropdown_background"
            android:layout_marginBottom="24dp"/>

        <!-- Personagem de voz -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Voz do Personagem:" android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <Spinner android:id="@+id/spinnerCharacter"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_box_background"
            android:popupBackground="@color/spinner_dropdown_background"
            android:layout_marginBottom="24dp"/>

        <!-- Alertas de voz (thresholds) -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Alertas de voz:" android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Voz baixa:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvVoiceLowValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="10%" android:textColor="#4ADE80" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekVoiceLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Voz crítica:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvVoiceCriticalValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="5%" android:textColor="#F59E0B" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekVoiceCritical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Voz quase acabando:"
                android:textColor="@color/text_primary"/>
            <TextView android:id="@+id/tvVoiceVeryLowValue"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2%" android:textColor="#EF4444" android:textStyle="bold"/>
        </LinearLayout>

        <SeekBar android:id="@+id/seekVoiceVeryLow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <!-- ============================================================ -->
        <!-- BOTÕES DE TESTE (Bip, TTS, Voz)                               -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnTestBeep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="🔊 Bip"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/btnTestTTS"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="🗣️ TTS"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />

            <Button
                android:id="@+id/btnTestVoice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🎭 Voz"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />

        </LinearLayout>

        <!-- Botão Salvar (oculto) -->
        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Configurações"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
