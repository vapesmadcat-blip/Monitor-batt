<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Painel de Status Reorganizado (Ocupa toda a largura, sem toggle de tema) -->
        <LinearLayout
            android:id="@+id/layoutStatsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:background="@drawable/stat_card_background"
            android:padding="12dp"
            android:elevation="2dp">

            <!-- Linha 1: Cabeçalho com Status e Velocidade -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvVisualIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔋"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ESTATÍSTICAS DA BATERIA"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvChargingSpeedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textColor="#F59E0B"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/stat_badge_background"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"/>
            </LinearLayout>

            <!-- Linha 2: Dados Principais em Grid Horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Coluna 1: Corrente -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CORRENTE" android:textSize="9sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvBatteryCurrent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-- mA" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Coluna 2: Potência -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="POTÊNCIA" android:textSize="9sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvBatteryPower" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-- W" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Coluna 3: Temperatura -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TEMP." android:textSize="9sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvBatteryTemp" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-- °C" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                </LinearLayout>

                <!-- Coluna 4: Tensão -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="TENSÃO" android:textSize="9sp" android:textColor="@color/text_secondary"/>
                    <TextView android:id="@+id/tvBatteryVoltage" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-- V" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Linha 3: Barra de Progresso Discreta -->
            <ProgressBar
                android:id="@+id/pbChargingSpeed"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:progressDrawable="@drawable/charging_gauge"/>
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitor de Bateria Pro"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Alerta de Mau Contato -->
        <LinearLayout
            android:id="@+id/layoutBadContactAlert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFF3B30"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ POSSÍVEL PROBLEMA NO CABO"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"/>
            <Button
                android:id="@+id/btnDismissBadContact"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:text="OK"
                android:textColor="#FF3B30"
                android:backgroundTint="#FFFFFF" />
        </LinearLayout>

        <!-- Bateria Visual -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="460dp"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:id="@+id/batteryContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <RelativeLayout
                    android:layout_width="290dp"
                    android:layout_height="440dp"
                    android:background="@drawable/battery_shell">
                    <View
                        android:id="@+id/batteryFill"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_alignParentBottom="true"
                        android:layout_margin="8dp"
                        android:background="@drawable/battery_fill_mid" />
                    <TextView
                        android:id="@+id/tvChargingBolt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="⚡"
                        android:textSize="40sp"
                        android:visibility="gone" />
                </RelativeLayout>
            </LinearLayout>
            <ImageView
                android:id="@+id/ivMascot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/battery_mascot_1"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvBigPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:text="--%"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Status e Bip Visual -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitoramento: DESATIVADO"
                android:textColor="#FF4D4F"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvBipIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="🔊"
                android:textSize="24sp"
                android:alpha="0.3" />
        </LinearLayout>

        <!-- Botões de Ação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <Button
                android:id="@+id/btnMonitor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="▶ ATIVAR MONITOR"
                android:backgroundTint="@color/green" />
            <Button
                android:id="@+id/btnMute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🔇 SILENCIAR"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- ÁREA BIP (NOVO QUADRO)                                        -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/layoutBipArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/stat_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ÁREA BIP"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBeep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ativar Bip"
                android:textColor="@color/text_primary"
                app:useMaterialThemeColors="true" />

            <!-- Volume do Bip -->
            <LinearLayout
                android:id="@+id/layoutBeepVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Volume do Bip:"
                        android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/tvBeepVolumeValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80%" android:textColor="#4ADE80" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekBeepVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="80"/>
            </LinearLayout>

            <!-- Começar quando (Threshold) -->
            <LinearLayout
                android:id="@+id/layoutBeepThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Começar quando (limite):"
                        android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/tvThresholdValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10%" android:textColor="#4ADE80" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekThreshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="25"
                    android:progress="5"/>
            </LinearLayout>

            <!-- Intervalo do Bip -->
            <LinearLayout
                android:id="@+id/layoutBeepInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Intervalo do Bip:"
                        android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/tvIntervalValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="15 seg" android:textColor="#4ADE80" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekInterval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="11"
                    android:progress="2"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnTestBeep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="🔊 Testar Bip"
                android:backgroundTint="@color/button_secondary_background"
                android:textColor="@color/button_secondary_text" />
        </LinearLayout>

        <!-- ============================================================ -->
        <!-- ÁREA VOZ (NOVO QUADRO)                                        -->
        <!-- ============================================================ -->
        <LinearLayout
            android:id="@+id/layoutVoiceArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/stat_card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ÁREA VOZ"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchTts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ativar TTS (síntese)"
                android:textColor="@color/text_primary"
                app:useMaterialThemeColors="true" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchCharacterVoice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ativar Personagem"
                android:textColor="@color/text_primary"
                app:useMaterialThemeColors="true" />

            <!-- Seleção de Personagem -->
            <LinearLayout
                android:id="@+id/layoutCharacterSelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Escolher Personagem:" android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerCharacter"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_box_background"
                    android:popupBackground="@color/spinner_dropdown_background"/>
            </LinearLayout>

            <!-- Volume da Voz -->
            <LinearLayout
                android:id="@+id/layoutVoiceVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Volume da Voz:"
                        android:textColor="@color/text_primary"/>
                    <TextView android:id="@+id/tvVoiceVolumeValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="80%" android:textColor="#4ADE80" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekVoiceVolume"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="80"/>
            </LinearLayout>

            <!-- Porcentagens de Alerta -->
            <LinearLayout
                android:id="@+id/layoutVoiceThresholds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">
                
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Porcentagens de Alerta:" android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Voz baixa:" />
                    <TextView android:id="@+id/tvVoiceLowValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="10%" android:textColor="#4ADE80" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekVoiceLow" android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Voz crítica:" />
                    <TextView android:id="@+id/tvVoiceCriticalValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="5%" android:textColor="#F59E0B" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekVoiceCritical" android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Voz muito baixa:" />
                    <TextView android:id="@+id/tvVoiceVeryLowValue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2%" android:textColor="#EF4444" android:textStyle="bold"/>
                </LinearLayout>
                <SeekBar android:id="@+id/seekVoiceVeryLow" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <Button
                    android:id="@+id/btnTestTTS"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="🗣️ Testar TTS"
                    android:backgroundTint="@color/button_secondary_background"
                    android:textColor="@color/button_secondary_text" />
                <Button
                    android:id="@+id/btnTestVoice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="🎭 Testar Voz"
                    android:backgroundTint="@color/button_secondary_background"
                    android:textColor="@color/button_secondary_text" />
            </LinearLayout>
        </LinearLayout>

        <!-- Configurações Extras -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Iniciar com o Android"
            android:textColor="@color/text_primary"
            app:useMaterialThemeColors="true" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Estilo Visual:" android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/spinnerVisualStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_box_background"
            android:popupBackground="@color/spinner_dropdown_background"
            android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btnSobre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sobre o App"
            android:backgroundTint="@color/button_secondary_background"
            android:textColor="@color/button_secondary_text"
            android:layout_marginBottom="24dp"/>

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salvar Configurações"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
