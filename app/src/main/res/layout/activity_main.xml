<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#05070A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor de Bateria"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#F9FAFB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Visual bonito e alerta configurável"
            android:textSize="14sp"
            android:textColor="#8B95A7" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <View
                android:layout_width="72dp"
                android:layout_height="18dp"
                android:background="@drawable/battery_cap" />

            <FrameLayout
                android:layout_width="188dp"
                android:layout_height="360dp"
                android:layout_marginTop="-2dp"
                android:background="@drawable/battery_shell"
                android:padding="12dp">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom"
                    android:max="100"
                    android:progress="50"
                    android:progressDrawable="@android:color/transparent"
                    android:rotation="180"
                    android:scaleY="8" />

                <View
                    android:id="@+id/batteryFill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom"
                    android:background="@drawable/battery_fill_high" />

                <View
                    android:id="@+id/batteryGloss"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_gravity="top"
                    android:background="@drawable/battery_gloss" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="50%"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="BATERIA"
            android:textAllCaps="true"
            android:letterSpacing="0.18"
            android:textSize="18sp"
            android:textColor="#6B7280" />

        <TextView
            android:id="@+id/tvAlertMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Normal"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#22C55E" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:background="#11161C"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quando começar a avisar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F3F4F6" />

            <TextView
                android:id="@+id/tvThresholdValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="10%"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#60A5FA" />

            <SeekBar
                android:id="@+id/seekThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escolha entre 5% e 30%"
                android:textSize="13sp"
                android:textColor="#94A3B8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="#11161C"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intervalo do bip"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#F3F4F6" />

            <TextView
                android:id="@+id/tvIntervalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="15 segundos"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#60A5FA" />

            <SeekBar
                android:id="@+id/seekInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escolha entre 5 e 60 segundos"
                android:textSize="13sp"
                android:textColor="#94A3B8" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Salvar e iniciar monitor" />

        <Button
            android:id="@+id/btnMute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Silenciar" />

        <Button
            android:id="@+id/btnTestBeep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Testar bip" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Parar monitor" />

    </LinearLayout>
</ScrollView>
