<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Nome da Empresa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nexus Soluções Globais"
            android:textColor="#4ADE80"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Descrição -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desenvolvemos soluções sob medida para o seu negócio."
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <!-- Áreas de Atuação -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Áreas de Atuação"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Gestão de Táxi e Frotas\n• Hospitais Veterinários\n• Educação e Ensino\n• Saúde e Controle de Medicamentos"
            android:textColor="#AAAAAA"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="40dp"/>

        <!-- Contato -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contato"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="contato.nexusbr@gmail.com"
            android:textColor="#4ADE80"
            android:textSize="16sp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Soluções personalizadas para o seu dia a dia."
            android:textColor="#888888"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="60dp"/>

    </LinearLayout>
</ScrollView>