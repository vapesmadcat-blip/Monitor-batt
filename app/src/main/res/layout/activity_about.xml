<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ícone do app -->
        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Ícone do aplicativo" />

        <!-- Nome do App -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitor de Bateria Pro"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- Versão -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Versão 1.2.1"
            android:textAppearance="?attr/textAppearanceCaption"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Descrição do App -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monitora a bateria em segundo plano e emite alertas sonoros e visuais quando o nível estiver baixo — mesmo com a tela apagada."
            android:textAppearance="?attr/textAppearanceBody2"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personalize o limiar de alerta, o intervalo dos bips, escolha uma voz de personagem e acompanhe a velocidade de carga/descarga em tempo real."
            android:textAppearance="?attr/textAppearanceBody2"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Divisória -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorControlHighlight"
            android:layout_marginBottom="24dp" />

        <!-- Empresa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desenvolvido por"
            android:textAppearance="?attr/textAppearanceOverline"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nexus Soluções Globais"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textStyle="bold"
            android:textColor="#4ADE80"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Soluções sob medida para o seu negócio."
            android:textAppearance="?attr/textAppearanceCaption"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Áreas de Atuação -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Áreas de Atuação"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Gestão de Táxi e Frotas\n• Hospitais Veterinários\n• Educação e Ensino\n• Saúde e Controle de Medicamentos"
            android:textAppearance="?attr/textAppearanceBody2"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="32dp" />

        <!-- Divisória -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorControlHighlight"
            android:layout_marginBottom="24dp" />

        <!-- Contato -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contato"
            android:textAppearance="?attr/textAppearanceSubtitle2"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="contato.nexusbr@gmail.com"
            android:textAppearance="?attr/textAppearanceBody1"
            android:textColor="#4ADE80"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

        <!-- Rodapé -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2024 Nexus Soluções Globais. Todos os direitos reservados."
            android:textAppearance="?attr/textAppearanceCaption"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>